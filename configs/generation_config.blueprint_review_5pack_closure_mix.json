{
  "batch_name": "blueprint_review_5pack_closure_mix",
  "dataset_count": 5,
  "llm": {
    "provider": "gateway",
    "model": "@gemini/gemini-2.5-flash",
    "base_url": "https://api.portkey.ai/v1",
    "api_key_env": "GATEWAY_API_KEY"
  },
  "scenario_type": "psychological_teacher_student",
  "prompt_language": "en",
  "target_role": "student",
  "sessions_per_conversation": 5,
  "turns_per_conversation": 150,
  "stage_count": 5,
  "question_count": 24,
  "output_root": "data/generated_batches",
  "output_naming": {
    "append_timestamp": false,
    "timestamp_format": "%Y%m%d_%H%M%S"
  },
  "persona_selection": {
    "mode": "random_seeded",
    "seed": 36
  },
  "blueprint_generation": {
    "enable_repair": true,
    "max_repair_attempts": 1,
    "fixed_events_per_session": 3
  },
  "conversation_generation": {
    "mode": "single_agent",
    "request_timeout_seconds": 1200
  }
}
